{
    "model": {
        "layers": 8,
        "imageSize": 48,
        "patchSize": 8,
        "embedDim": 256,
        "heads": 8
    },
    "dataset": {
        "fontSize": 32,
        "maps": "bitmaps",
        "split": "holdout",
        "directory": "dataset",
        "method": "upper",
        "standardFonts": [
            "Calibri",
            "Arial",
            "Tahoma",
            "Times New Roman"
        ],
        "stylizedFonts": [
            "Brush Script MT Italic",
            "Chiller Regular",
            "Goudy Stout Regular",
            "Jokerman Regular"
        ]
    },
    "batchSize": 128,
    "learningRate": 0.0001,
    "epochs": 80
}